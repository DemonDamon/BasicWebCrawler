# 微信公众号定向采集子系统 — 环境变量模板
# 复制为 .env 并按需修改：cp .env.example .env

# ── 数据库 ────────────────────────────────────────────────────
# 默认使用 SQLite（文件在项目根目录）
COLLECTOR_DB_URL=sqlite:///./wechat_collector.db

# 远程 PostgreSQL 示例（生产环境推荐）：
# COLLECTOR_DB_URL=postgresql+psycopg2://user:password@localhost:5432/wechat_collector

# ── API 鉴权 ──────────────────────────────────────────────────
# 插件和服务端必须填写相同的 Token，自己生成一个随机串：
#   python -c "import secrets; print(secrets.token_hex(32))"
COLLECTOR_API_TOKEN=change-me-in-production

# ── Worker 调度参数（可选，以下为默认值）────────────────────
# 两次抓取之间的随机等待范围（秒）
WORKER_MIN_DELAY_SECONDS=30
WORKER_MAX_DELAY_SECONDS=180
# 候选池为空时的轮询间隔（秒）
WORKER_IDLE_SLEEP_SECONDS=60
# 单次 HTTP 请求超时（秒）
WORKER_FETCH_TIMEOUT_SECONDS=20

# ── RSSHub 巡检参数（可选，以下为默认值）────────────────────
# 本地 RSSHub 实例地址（docker run -d -p 1200:1200 diygod/rsshub）
RSSHUB_BASE_URL=http://127.0.0.1:1200
# 巡检轮询间隔（秒，默认 30min）
RSS_POLL_INTERVAL_SECONDS=1800
# 每条路由请求之间的随机延迟范围（防限速）
RSS_REQUEST_DELAY_MIN_SECONDS=2.0
RSS_REQUEST_DELAY_MAX_SECONDS=5.0
# RSS 请求超时（秒）
RSS_REQUEST_TIMEOUT_SECONDS=15
# 同一公众号两次抓取之间的最短间隔（秒）
SCHEDULER_MAX_ACCOUNT_INTERVAL_SECONDS=60
# 发现任务请求延迟（秒）
DISCOVERY_REQUEST_DELAY_SECONDS=1.5

# ── Playwright 搜狗发现（可选，默认关闭）────────────────────
# 显式开启后才运行 sogou_poller；首次建议 headful 手动过验证码养 cookie
# SOGOU_PLAYWRIGHT_ENABLED=true
# SOGOU_POLL_INTERVAL_SECONDS=14400
# SOGOU_MAX_ARTICLES_PER_ACCOUNT=5
# SOGOU_USER_DATA_DIR=.playwright/sogou
# SOGOU_HEADLESS=true
# SOGOU_ARTICLE_DELAY_MIN_SECONDS=1.5
# SOGOU_ARTICLE_DELAY_MAX_SECONDS=3.0
# SOGOU_ACCOUNT_DELAY_MIN_SECONDS=3.0
# SOGOU_ACCOUNT_DELAY_MAX_SECONDS=6.0
# SOGOU_PAGE_TIMEOUT_MS=30000
