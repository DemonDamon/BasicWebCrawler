# ====================================
# BasicWebCrawler 大模型 API 配置
# ====================================
# 
# 使用说明：
# 1. 复制此文件为 .env
# 2. 至少配置一个厂商的 API Key
# 3. 推荐使用 DeepSeek（性价比最高）
# 
# 获取 API Key：
# - DeepSeek: https://platform.deepseek.com/
# - 百炼(阿里云): https://dashscope.aliyuncs.com/
# - Kimi: https://platform.moonshot.cn/
# - 硅基流动: https://cloud.siliconflow.cn/
# 
# ====================================

# DeepSeek（推荐，性价比最高）
DEEPSEEK_API_KEY=

# 百炼（阿里云通义千问，中文处理好）
BAILIAN_API_KEY=

# Kimi（月之暗面，超长上下文）
KIMI_API_KEY=

# 硅基流动（开源模型集成）
SILICONFLOW_API_KEY=